# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for all text files
*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Force CRLF line endings for Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
